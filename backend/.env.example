# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/paymentdb

# Security — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
ENVIRONMENT=development

# CORS — comma-separated frontend URLs
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
LOGIN_RATE_LIMIT=10/minute

# Auto-create demo accounts (director/manager/employee) when DB is empty
AUTO_SEED_DEMO=true

# One-click demo login by role (disable in production)
DEMO_MODE=true

# Optional — Redis cache
REDIS_URL=redis://localhost:6379
